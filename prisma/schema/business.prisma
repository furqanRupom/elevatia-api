model Business {
  id      String @id @default(uuid())
  ownerId String // User who owns this business
  name    String
  slug    String @unique // URL-friendly name (e.g., "joe-pizza")

  // Basic info
  description   String?
  categoryId    String
  logoUrl       String? // Optional image URL
  coverImageUrl String?

  // Contact
  address String?
  city    String?
  state   String?
  zipCode String?
  phone   String?
  email   String?
  website String?

  // Social links (Premium feature)
  instagram String?
  facebook  String?
  x         String?
  linkedin  String?

  // Business hours (JSON store)
  hours Json? // { "monday": "9am-5pm", "tuesday": "..." }

  // SEO & visibility
  tags          String // ["pizza", "italian", "delivery"]
  featuredUntil DateTime? // When featured placement expires

  // Status
  status    ListingStatus @default(PENDING)
  viewCount Int           @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner        User           @relation(fields: [ownerId], references: [id])
  category     Category       @relation(fields: [categoryId], references: [id])
  subscription Subscription?
  reviews      Review[]
  savedBy      SavedListing[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([featuredUntil])
  @@map("business")
}
